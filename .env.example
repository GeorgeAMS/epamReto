# Groq API (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Modelos LLM (opcional)
LLM_BRAIN_MODEL=llama-3.3-70b-versatile
LLM_LIGHT_MODEL=llama-3.1-8b-instant

# Embeddings (RAG cloud/local)
EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=text-embedding-004

# Ollama (solo si EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Qdrant
QDRANT_URL=http://localhost:6333

# Langfuse (opcional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# PokéAPI
POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Entorno API (prod recomendado en Docker/nube)
ENV=dev
# Login básico (cámbialo en producción)
AUTH_USER=admin
AUTH_PASSWORD=admin12345
AUTH_TOKEN_SECRET=change-me-in-env-very-long-random-secret
AUTH_TOKEN_EXP_MINUTES=480

# Límite por IP para POST /chat y /chat/stream (requests/minuto). Ver README «Seguridad».
# CHAT_RATE_LIMIT_PER_MINUTE=60

# Orígenes CORS permitidos (coma-separados). En producción incluye tu front Vercel:
# API_CORS_ORIGINS=https://pokedex-arcana-frontend.vercel.app,http://localhost:8080
