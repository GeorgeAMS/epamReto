# ---------------------------------------------------------------------------
# Pokédex Arcana — .gitignore
# Cubre Python (backend + dominio) y Node/Next.js (frontend).
# ---------------------------------------------------------------------------

# --- Secrets ---------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
pip-wheel-metadata/
.installed.cfg
MANIFEST

# Virtualenvs
.venv/
venv/
env/
ENV/

# uv / pip
.uv/
.pip-cache/

# Tests / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# --- Datos / cachés del proyecto ------------------------------------------
data/cache/
data/processed/
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet
*.duckdb
*.duckdb.wal
pokeapi_cache.sqlite*
qdrant_storage/

# --- Node / Next.js --------------------------------------------------------
node_modules/
.pnpm-store/
.next/
out/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Docker / infra --------------------------------------------------------
.docker/
docker-compose.override.yml

# --- IDEs / OS -------------------------------------------------------------
.vscode/
!.vscode/settings.example.json
.idea/
.DS_Store
Thumbs.db
desktop.ini

# --- Reportes generados ----------------------------------------------------
reports/
*.pdf
!docs/**/*.pdf

# --- Langfuse local --------------------------------------------------------
langfuse-data/
